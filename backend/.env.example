# Application
APP_NAME=Decarbonization Platform
DEBUG=True
ENVIRONMENT=development

# Climatiq API
CLIMATIQ_API_KEY=your_climatiq_api_key_here
CLIMATIQ_BASE_URL=https://api.climatiq.io
CLIMATIQ_PREVIEW_URL=https://preview.api.climatiq.io

# Database
DATABASE_URL=postgresql://carbon_user:carbon_password@localhost:5432/decarbonization_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=1000

# Batch Processing
BATCH_CHUNK_SIZE=100
BATCH_TIMEOUT_SECONDS=300

# Cache TTL (seconds)
EMISSION_FACTOR_CACHE_TTL=86400
