# .env.example
# Copy this to .env and update values for your environment

# Application
APP_NAME=Decarbonization Platform API
ENVIRONMENT=development
DEBUG=true

# Security - CHANGE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://decarb_user:decarb_password@postgres:5432/decarb_db

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Gemini API 
GEMINI_API_KEY=AIzaSyAG7HqxdX73tIO5a1VrJgNSyefuy3xwwJ4
GEMINI_MODEL=gemini-2.0-flash

# ==================== NEW: DSPy Configuration ====================
DSPY_TEMPERATURE=0.3
DSPY_MAX_TOKENS=150

# ==================== NEW: Classification Configuration ====================
MIN_CONFIDENCE_THRESHOLD=0.80
CLASSIFICATION_TIMEOUT=10
BATCH_CLASSIFICATION_SIZE=50

#Feature Flags ====================
ENABLE_DSPY_AGENTS=true
ENABLE_CONFIDENCE_FLAGGING=true
ENABLE_AUDIT_LOGGING=true

# Logging
LOG_LEVEL=INFO
