# .env.example
# Copy this to .env and update values for your environment

# Application
APP_NAME=Decarbonization Platform API
ENVIRONMENT=development
DEBUG=true

# Security - CHANGE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://decarb_user:decarb_password@postgres:5432/decarb_db

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

GEMINI_API_KEY=your-gemini-api-key-here
AI_MIN_CONFIDENCE_THRESHOLD=0.80
