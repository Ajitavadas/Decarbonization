# Decarbonization Platform Environment Variables
# Copy this file to .env and update with your values

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars

# AI Configuration
GEMINI_API_KEY=your-gemini-api-key-from-google-ai-studio
AI_MIN_CONFIDENCE_THRESHOLD=0.80

# Optional: Database (defaults are fine for development)
# POSTGRES_USER=decarb_user
# POSTGRES_PASSWORD=decarb_password
# POSTGRES_DB=decarb_db
